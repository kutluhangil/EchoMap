# Echo Map environment variables. Copy to .env and fill in.
# EXPO_PUBLIC_ vars are bundled into the app and readable on-device — never put
# secrets behind that prefix.

# Mapbox public access token (pk....), used at runtime by the map.
# Get one at https://account.mapbox.com/access-tokens
EXPO_PUBLIC_MAPBOX_TOKEN=

# Mapbox secret download token (sk....), used only by EAS Build to fetch the
# native SDK. Not bundled into the app.
MAPBOX_DOWNLOAD_TOKEN=

# Optional Supabase cloud backup (opt-in). Leave blank to stay fully local-first.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
